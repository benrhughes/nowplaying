# Example Caddyfile for proxying to bcmasto container
# Replace example.com with your domain
# Copy this to your main Caddy config or use it standalone

bandcamp.example.com {
  # Caddy will automatically handle SSL certificates
  # Just point your domain to your server
  
  reverse_proxy localhost:3000 {
    # Keep connections alive
    header_up Connection "Upgrade"
    header_up Upgrade "websocket"
  }
}

# Alternative: If running Caddy in the same Docker network as bcmasto
# bandcamp.example.com {
#   reverse_proxy bcmasto:3000
# }
